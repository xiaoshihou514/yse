{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "盐水鹅",
  "version": "0.1.0",
  "identifier": "org.yse.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "{ [ -d ../frontend/node_modules ] && [ ../frontend/package.json -ot ../frontend/node_modules/.package-lock.json ] ; } || npm --prefix ../frontend install; npm --prefix ../frontend run dev",
    "beforeBuildCommand": "cd ../frontend && { [ -d node_modules ] && [ package.json -ot node_modules/.package-lock.json ] ; } || npm i && { [ -f dist/index.html ] && ! find src package.json -newer dist/index.html -not -type d | grep -q . ; } || npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "盐水鹅",
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../icon.png"]
  }
}
